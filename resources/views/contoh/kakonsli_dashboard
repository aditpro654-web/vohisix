        const MOCK_STUDENTS_BY_CLASS = {
            "XIII SIJA 1": [
                { id: 1, nama: "Aril Pratama", nis: "210231", foto: "https://randomuser.me/api/portraits/men/1.jpg", status_lamaran: "Direview", berkas: "Lengkap", perusahaan_id: 1, berkas_files: { ktp: { status: "Selesai", date: "03 Nov 2025", file_url: null }, sehat: { status: "Selesai", date: "04 Nov 2025", file_url: null }, bpjs: { status: "Proses", date: "-", file_url: null } } },
                { id: 2, nama: "Melvin", nis: "210232", foto: "https://randomuser.me/api/portraits/men/2.jpg", status_lamaran: "Diterima", berkas: "Lengkap", perusahaan_id: 2, berkas_files: { ktp: { status: "Selesai", date: "01 Nov 2025", file_url: null }, sehat: { status: "Selesai", date: "02 Nov 2025", file_url: null }, bpjs: { status: "Selesai", date: "05 Nov 2025", file_url: null } } },
                { id: 3, nama: "Lintang", nis: "210233", foto: "https://randomuser.me/api/portraits/women/1.jpg", status_lamaran: "Ditolak", berkas: "Kurang", perusahaan_id: 3, berkas_files: { ktp: { status: "Selesai", date: "30 Oct 2025", file_url: null }, sehat: { status: "Belum", date: "-", file_url: null }, bpjs: { status: "Belum", date: "-", file_url: null } } },
                { id: 4, nama: "Dewi Sartika", nis: "210234", foto: "https://randomuser.me/api/portraits/women/2.jpg", status_lamaran: "Diterima", berkas: "Lengkap", perusahaan_id: 1, berkas_files: { ktp: { status: "Selesai", date: "02 Nov 2025", file_url: null }, sehat: { status: "Selesai", date: "03 Nov 2025", file_url: null }, bpjs: { status: "Selesai", date: "04 Nov 2025", file_url: null } } },
                { id: 5, nama: "Bima Sakti", nis: "210235", foto: "https://randomuser.me/api/portraits/men/3.jpg", status_lamaran: "Direview", berkas: "Kurang", perusahaan_id: 2, berkas_files: { ktp: { status: "Selesai", date: "01 Nov 2025", file_url: null }, sehat: { status: "Belum", date: "-", file_url: null }, bpjs: { status: "Belum", date: "-", file_url: null } } }
            ],
            "XIII SIJA 2": [
                { id: 6, nama: "Siti Aminah", nis: "210236", foto: "https://randomuser.me/api/portraits/women/3.jpg", status_lamaran: "Diterima", berkas: "Lengkap", perusahaan_id: 2, berkas_files: { ktp: { status: "Selesai", date: "05 Nov 2025", file_url: null }, sehat: { status: "Selesai", date: "06 Nov 2025", file_url: null }, bpjs: { status: "Selesai", date: "07 Nov 2025", file_url: null } } },
                { id: 7, nama: "Rizki Fadillah", nis: "210237", foto: "https://randomuser.me/api/portraits/men/4.jpg", status_lamaran: "Direview", berkas: "Lengkap", perusahaan_id: 3, berkas_files: { ktp: { status: "Selesai", date: "04 Nov 2025", file_url: null }, sehat: { status: "Selesai", date: "05 Nov 2025", file_url: null }, bpjs: { status: "Proses", date: "-", file_url: null } } },
                { id: 8, nama: "Nadia Putri", nis: "210238", foto: "https://randomuser.me/api/portraits/women/4.jpg", status_lamaran: "Ditolak", berkas: "Kurang", perusahaan_id: 1, berkas_files: { ktp: { status: "Selesai", date: "03 Nov 2025", file_url: null }, sehat: { status: "Belum", date: "-", file_url: null }, bpjs: { status: "Belum", date: "-", file_url: null } } },
                { id: 9, nama: "Andi Wijaya", nis: "210239", foto: "https://randomuser.me/api/portraits/men/5.jpg", status_lamaran: "Diterima", berkas: "Lengkap", perusahaan_id: 2, berkas_files: { ktp: { status: "Selesai", date: "06 Nov 2025", file_url: null }, sehat: { status: "Selesai", date: "07 Nov 2025", file_url: null }, bpjs: { status: "Selesai", date: "08 Nov 2025", file_url: null } } },
                { id: 10, nama: "Maya Sari", nis: "210240", foto: "https://randomuser.me/api/portraits/women/5.jpg", status_lamaran: "Direview", berkas: "Lengkap", perusahaan_id: 3, berkas_files: { ktp: { status: "Selesai", date: "05 Nov 2025", file_url: null }, sehat: { status: "Selesai", date: "06 Nov 2025", file_url: null }, bpjs: { status: "Proses", date: "-", file_url: null } } }
            ]
        };

        let selectedClass = "XIII SIJA 1";
        let searchQuery = "";
        let statusFilter = "Semua Status";
        let selectedStudent = null;
        let activeTab = "berkas";
        let filePreviewData = null;

        function getStatusClass(status) {
            if (status === "Diterima") return "badge-diterima";
            if (status === "Ditolak") return "badge-ditolak";
            return "badge-direview";
        }

        function getBerkasClass(berkas) {
            return berkas === "Lengkap" ? "badge-lengkap" : "badge-kurang";
        }

        function getFilteredData() {
            const students = MOCK_STUDENTS_BY_CLASS[selectedClass] || [];
            return students.filter(student => {
                const dudi = MOCK_DUDI.find(d => d.id === student.perusahaan_id);
                const matchesSearch = student.nama.toLowerCase().includes(searchQuery.toLowerCase()) ||
                                    student.nis.includes(searchQuery) ||
                                    (dudi && dudi.nama_dudi.toLowerCase().includes(searchQuery.toLowerCase()));
                const matchesStatus = statusFilter === "Semua Status" || student.status_lamaran === statusFilter;
                return matchesSearch && matchesStatus;
            });
        }

        function getStats() {
            const students = MOCK_STUDENTS_BY_CLASS[selectedClass] || [];
            const total = students.length;
            const ditempatkan = students.filter(s => s.status_lamaran === "Diterima").length;
            const berkasKurang = students.filter(s => s.berkas === "Kurang").length;
            return { total, ditempatkan, berkasKurang };
        }

        function formatDate() {
            const today = new Date();
            const formattedDate = today.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
            const formattedTime = today.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
            return { formattedDate, formattedTime };
        }

        function showFilePreview(berkasType, studentName, statusFile) {
            let fileName = `${berkasType}_${studentName.replace(/\s/g, '')}.pdf`;
            let previewContent = `
                <div style="background: #f1f5f9; border-radius: 20px; padding: 30px; margin: 16px 0;">
                    <div style="font-size: 64px; margin-bottom: 16px;">📄</div>
                    <p style="font-weight: 700; color: #003056; margin-bottom: 8px;">${berkasType}</p>
                    <p style="font-size: 13px; color: #334155;">Nama file: ${fileName}</p>
                    <p style="font-size: 12px; color: #64748b; margin-top: 12px;">Status: ${statusFile}</p>
                    <div style="margin-top: 24px; padding: 16px; background: white; border-radius: 16px; border: 1px dashed #003056;">
                        ⚡ Preview dokumen (simulasi):<br>
                        <span style="font-size: 12px;">Berkas ${berkasType} milik ${studentName} akan ditampilkan di sini.</span>
                    </div>
                </div>
            `;
            filePreviewData = { title: `Preview - ${berkasType}`, content: previewContent };
            render();
        }

        function closeFilePreview() {
            filePreviewData = null;
            render();
        }

        function render() {
            const filteredData = getFilteredData();
            const stats = getStats();
            const { formattedDate, formattedTime } = formatDate();
            const classOptions = ["XIII SIJA 1", "XIII SIJA 2"];
            const statusOptions = ["Semua Status", "Diterima", "Ditolak", "Direview"];

            let html = `
                <div class="min-h-screen bg-[#f8fafc]" style="font-family: 'Plus Jakarta Sans', sans-serif;">
                    <header style="background-color: #003056; color: white; padding: 40px 32px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);">
                        <div style="max-width: 1280px; margin: 0 auto; display: flex; flex-direction: column; justify-content: space-between; align-items: center; gap: 24px;">
                            <div>
                                <h1 style="font-size: 1.875rem; font-weight: 800; letter-spacing: -0.025em; margin-bottom: 8px;">Dashboard Ketua Jurusan</h1>
                                <p style="color: #cbd5e1; font-size: 0.875rem; font-weight: 500;">Booking PKL SMKN 6 Malang • Manajemen Semua Kelas</p>
                            </div>
                            <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;">
                                <div style="text-align: center; background-color: rgba(255,255,255,0.1); padding: 12px 20px; border-radius: 16px; min-width: 100px;">
                                    <span style="display: block; font-size: 1.5rem; font-weight: 700;">${stats.total}</span>
                                    <span style="font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; color: #cbd5e1;">Total Siswa</span>
                                </div>
                                <div style="text-align: center; background-color: rgba(255,255,255,0.1); padding: 12px 20px; border-radius: 16px; min-width: 100px;">
                                    <span style="display: block; font-size: 1.5rem; font-weight: 700; color: #86efac;">${stats.ditempatkan}</span>
                                    <span style="font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; color: #cbd5e1;">Ditempatkan</span>
                                </div>
                                <div style="text-align: center; background-color: rgba(255,255,255,0.1); padding: 12px 20px; border-radius: 16px; min-width: 100px;">
                                    <span style="display: block; font-size: 1.5rem; font-weight: 700; color: #fca5a5;">${stats.berkasKurang}</span>
                                    <span style="font-size: 9px; text-transform: uppercase; letter-spacing: 0.05em; color: #cbd5e1;">Berkas Kurang</span>
                                </div>
                            </div>
                        </div>
                    </header>

                    <main style="max-width: 1280px; margin: 0 auto; padding: 40px 16px;">
                        <div style="background-color: white; border-radius: 24px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); overflow: hidden; border: 1px solid #e2e8f0;">
                            <div style="background-color: #003056; padding: 24px; border-bottom: 1px solid rgba(255,255,255,0.1); display: flex; flex-direction: column; gap: 16px;">
                                <div style="display: flex; flex-direction: row; flex-wrap: wrap; gap: 16px; justify-content: space-between; align-items: center;">
                                    <div style="display: flex; flex-wrap: wrap; gap: 16px;">
                                        <input type="text" id="searchInput" placeholder="Cari Siswa atau NIS..." value="${searchQuery.replace(/"/g, '&quot;')}" style="padding: 10px 16px; border: 1px solid rgba(255,255,255,0.3); border-radius: 12px; font-size: 0.875rem; width: 280px; background-color: rgba(255,255,255,0.1); color: white;">
                                        <div style="position: relative;">
                                            <select id="statusSelect" class="toolbar-select custom-select" style="background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.3); border-radius: 12px; padding: 10px 32px 10px 16px; font-size: 0.875rem; color: white; font-weight: 600; width: 160px;">
                                                ${statusOptions.map(s => `<option value="${s}" ${statusFilter === s ? 'selected' : ''}>${s}</option>`).join('')}
                                            </select>
                                        </div>
                                    </div>
                                    <div style="display: flex; gap: 12px;">
                                        <select id="classSelectToolbar" class="custom-select" style="background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.3); border-radius: 12px; padding: 10px 32px 10px 16px; font-size: 0.875rem; color: white; font-weight: 600;">
                                            ${classOptions.map(c => `<option value="${c}" ${selectedClass === c ? 'selected' : ''}>${c}</option>`).join('')}
                                        </select>
                                        <button id="printBtn" style="background-color: white; color: #003056; border: none; padding: 10px 24px; border-radius: 12px; font-size: 0.875rem; font-weight: 700; cursor: pointer;">Cetak Laporan</button>
                                    </div>
                                </div>
                            </div>

                            <div class="table-wrapper">
                                <table style="width: 100%; text-align: left; border-collapse: collapse;">
                                    <thead>
                                        <tr style="background-color: #003056; color: white; font-size: 11px; text-transform: uppercase; font-weight: 800; letter-spacing: 0.05em;">
                                            <th style="padding: 16px 24px; text-align: center; width: 70px;">No</th>
                                            <th style="padding: 16px 24px;">Foto</th>
                                            <th style="padding: 16px 24px;">Nama Siswa</th>
                                            <th style="padding: 16px 24px;">NIS</th>
                                            <th style="padding: 16px 24px;">Berkas</th>
                                            <th style="padding: 16px 24px;">Perusahaan Mitra</th>
                                            <th style="padding: 16px 24px; text-align: center;">Status</th>
                                            <th style="padding: 16px 24px; text-align: center;">Aksi</th>
                                        </tr>
                                    </thead>
                                    <tbody style="border-top: 1px solid #f1f5f9;">
            `;

            if (filteredData.length === 0) {
                html += `<tr><td colspan="8" style="padding: 80px 24px; text-align: center; color: #94a3b8;">Data tidak ditemukan</td></tr>`;
            } else {
                filteredData.forEach((student, idx) => {
                    const dudi = MOCK_DUDI.find(d => d.id === student.perusahaan_id);
                    html += `
                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <td style="padding: 16px 24px; text-align: center; color: #94a3b8; font-size: 0.75rem; font-weight: 700;">${idx+1}</td>
                            <td style="padding: 16px 24px;"><img src="${student.foto}" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" onerror="this.src='https://placehold.co/100x100/003056/white?text=User'"></td>
                            <td style="padding: 16px 24px; font-weight: 700; color: #003056; font-size: 0.875rem;">${student.nama}</td>
                            <td style="padding: 16px 24px; color: #64748b; font-size: 0.75rem; font-weight: 700;">${student.nis}</td>
                            <td style="padding: 16px 24px;"><span style="padding: 4px 12px; font-size: 10px; font-weight: 700; border-radius: 9999px; border: 1px solid; display: inline-block; background-color: ${student.berkas === 'Lengkap' ? '#dcfce7' : '#fee2e2'}; color: ${student.berkas === 'Lengkap' ? '#15803d' : '#b91c1c'}; border-color: ${student.berkas === 'Lengkap' ? '#bbf7d0' : '#fecaca'};">${student.berkas}</span></td>
                            <td style="padding: 16px 24px;">
                                <div style="font-weight: 700; color: #334155; font-size: 0.875rem;">${dudi ? dudi.nama_dudi : "-"}</div>
                                ${dudi ? `<div style="font-size: 10px; color: #94a3b8;">${dudi.bidang_industri}</div>` : ""}
                            </td>
                            <td style="padding: 16px 24px; text-align: center;"><span style="padding: 4px 12px; border-radius: 9999px; font-size: 10px; font-weight: 700; border: 1px solid; background-color: ${student.status_lamaran === 'Diterima' ? '#dcfce7' : (student.status_lamaran === 'Ditolak' ? '#fee2e2' : '#fef3c7')}; color: ${student.status_lamaran === 'Diterima' ? '#15803d' : (student.status_lamaran === 'Ditolak' ? '#b91c1c' : '#b45309')};">${student.status_lamaran}</span></td>
                            <td style="padding: 16px 24px; text-align: center;"><button class="detail-btn" data-id="${student.id}" style="background-color: #003056; color: white; padding: 6px 14px; border-radius: 8px; font-size: 10px; font-weight: 700; border: none; cursor: pointer;">Detail</button></td>
                        </tr>
                    `;
                });
            }

            html += `
                                    </tbody>
                                </table>
                            </div>
                            <div style="background-color: #003056; color: rgba(255,255,255,0.7); padding: 16px 24px; display: flex; flex-direction: row; justify-content: space-between; align-items: center; gap: 12px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">
                                <span>Kelas: ${selectedClass} | Total data: ${filteredData.length} dari ${stats.total} Siswa</span>
                                <span>Update: ${formattedDate}, ${formattedTime}</span>
                            </div>
                        </div>
                    </main>
                </div>
            `;

            // MODAL DETAIL SISWA
            if (selectedStudent) {
                const dudi = MOCK_DUDI.find(d => d.id === selectedStudent.perusahaan_id);
                html += `
                    <div id="modalOverlay" style="position: fixed; inset: 0; z-index: 50; display: flex; align-items: center; justify-content: center; padding: 16px; background-color: rgba(0,0,0,0.5);" onclick="closeModal(event)">
                        <div class="modal-detail-container" onclick="event.stopPropagation()">
                            <div class="modal-left-profile" style="background-color: #003056; color: white; padding: 32px; display: flex; flex-direction: column; align-items: center; text-align: center;">
                                <img src="${selectedStudent.foto}" style="width: 128px; height: 128px; border-radius: 50%; object-fit: cover; border: 4px solid white; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); margin-bottom: 24px;">
                                <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 4px;">${selectedStudent.nama}</h2>
                                <p style="color: #bfdbfe; font-size: 0.875rem; margin-bottom: 24px;">${selectedStudent.nis}</p>
                                <div style="width: 100%; display: flex; flex-direction: column; gap: 12px; text-align: left;">
                                    <div style="display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.2);">
                                        <span style="font-size: 0.75rem; opacity: 0.7;">Status Lamaran</span>
                                        <span style="font-size: 0.75rem; font-weight: 700;">${selectedStudent.status_lamaran}</span>
                                    </div>
                                    <div style="display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.2);">
                                        <span style="font-size: 0.75rem; opacity: 0.7;">Kelengkapan Berkas</span>
                                        <span style="font-size: 0.75rem; font-weight: 700; color: ${selectedStudent.berkas === 'Lengkap' ? '#86efac' : '#fca5a5'}">${selectedStudent.berkas}</span>
                                    </div>
                                </div>
                                <button onclick="closeModal()" style="margin-top: 32px; width: 100%; background-color: rgba(255,255,255,0.1); border: none; padding: 12px; border-radius: 12px; font-size: 0.75rem; font-weight: 700; color: white; cursor: pointer;">Tutup Detail</button>
                            </div>
                            <div class="modal-right-content">
                                <div style="display: flex; border-bottom: 1px solid #e2e8f0; padding: 24px 24px 0 24px; gap: 32px;">
                                    <button id="tabBerkasBtn" style="padding-bottom: 12px; font-size: 0.875rem; font-weight: 700; background: none; border: none; cursor: pointer; ${activeTab === 'berkas' ? 'color: #003056; border-bottom: 2px solid #003056;' : 'color: #94a3b8;'}">Berkas Administrasi</button>
                                    <button id="tabPerusahaanBtn" style="padding-bottom: 12px; font-size: 0.875rem; font-weight: 700; background: none; border: none; cursor: pointer; ${activeTab === 'perusahaan' ? 'color: #003056; border-bottom: 2px solid #003056;' : 'color: #94a3b8;'}">Data Perusahaan PKL</button>
                                </div>
                                <div class="modal-right-scroll" style="flex:1; padding: 20px;">
                `;
                if (activeTab === 'berkas') {
                    html += `<div style="display: flex; flex-direction: column; gap: 14px;">
                                <div class="berkas-item-click" data-berkas="KTP/KIA" data-status="${selectedStudent.berkas_files.ktp.status}" style="display: flex; justify-content: space-between; align-items: center; padding: 14px; background-color: #f8fafc; border-radius: 14px;">
                                    <span style="font-weight: 700;">📄 KTP / KIA</span>
                                    <span style="padding: 4px 12px; border-radius: 9999px; font-size: 10px; font-weight: 700; background-color: ${selectedStudent.berkas_files.ktp.status === 'Selesai' ? '#dcfce7' : '#fef3c7'}; color: ${selectedStudent.berkas_files.ktp.status === 'Selesai' ? '#15803d' : '#b45309'};">${selectedStudent.berkas_files.ktp.status}</span>
                                </div>
                                <div class="berkas-item-click" data-berkas="Surat Sehat" data-status="${selectedStudent.berkas_files.sehat.status}" style="display: flex; justify-content: space-between; align-items: center; padding: 14px; background-color: #f8fafc; border-radius: 14px;">
                                    <span style="font-weight: 700;">🏥 Surat Sehat</span>
                                    <span style="padding: 4px 12px; border-radius: 9999px; font-size: 10px; font-weight: 700; background-color: ${selectedStudent.berkas_files.sehat.status === 'Selesai' ? '#dcfce7' : '#fef3c7'}; color: ${selectedStudent.berkas_files.sehat.status === 'Selesai' ? '#15803d' : '#b45309'};">${selectedStudent.berkas_files.sehat.status}</span>
                                </div>
                                <div class="berkas-item-click" data-berkas="BPJS Ketenagakerjaan" data-status="${selectedStudent.berkas_files.bpjs.status}" style="display: flex; justify-content: space-between; align-items: center; padding: 14px; background-color: #f8fafc; border-radius: 14px;">
                                    <span style="font-weight: 700;">🛡️ BPJS Ketenagakerjaan</span>
                                    <span style="padding: 4px 12px; border-radius: 9999px; font-size: 10px; font-weight: 700; background-color: ${selectedStudent.berkas_files.bpjs.status === 'Selesai' ? '#dcfce7' : (selectedStudent.berkas_files.bpjs.status === 'Proses' ? '#dbeafe' : '#fef3c7')}; color: ${selectedStudent.berkas_files.bpjs.status === 'Selesai' ? '#15803d' : (selectedStudent.berkas_files.bpjs.status === 'Proses' ? '#1d4ed8' : '#b45309')};">${selectedStudent.berkas_files.bpjs.status}</span>
                                </div>
                            </div>`;
                } else {
                    if (!dudi) html += `<div style="color: #94a3b8; text-align: center;">Data perusahaan tidak tersedia</div>`;
                    else {
                        // PERBAIKAN: perkecil padding, gap, font agar tidak kepotong
                        html += `<div style="display: flex; flex-direction: column; gap: 12px;">
                                    <div style="padding: 12px; background-color: #f8fafc; border-radius: 12px;"><p style="font-size: 0.7rem; color: #94a3b8; margin-bottom: 2px;">Nama Perusahaan</p><p style="font-weight: 700; font-size: 0.8rem;">${dudi.nama_dudi}</p></div>
                                    <div style="padding: 12px; background-color: #f8fafc; border-radius: 12px;"><p style="font-size: 0.7rem; color: #94a3b8; margin-bottom: 2px;">Bidang Industri</p><p style="font-weight: 700; font-size: 0.8rem;">${dudi.bidang_industri}</p></div>
                                    <div style="padding: 12px; background-color: #f8fafc; border-radius: 12px;"><p style="font-size: 0.7rem; color: #94a3b8; margin-bottom: 2px;">Jumlah Pegawai</p><p style="font-weight: 700; font-size: 0.8rem;">${dudi.jumlah_pegawai}</p></div>
                                    <div style="padding: 12px; background-color: #f8fafc; border-radius: 12px;"><p style="font-size: 0.7rem; color: #94a3b8; margin-bottom: 2px;">Website</p><p style="font-weight: 700; font-size: 0.8rem;">${dudi.website}</p></div>
                                    <div style="padding: 12px; background-color: #f8fafc; border-radius: 12px;"><p style="font-size: 0.7rem; color: #94a3b8; margin-bottom: 2px;">Penanggung Jawab</p><p style="font-weight: 700; font-size: 0.8rem;">${dudi.penanggung_jawab}</p></div>
                                    <div style="padding: 12px; background-color: #f8fafc; border-radius: 12px;"><p style="font-size: 0.7rem; color: #94a3b8; margin-bottom: 2px;">Kontak</p><p style="font-weight: 700; font-size: 0.8rem;">${dudi.telepon} | ${dudi.email}</p></div>
                                    <div style="padding: 12px; background-color: #f8fafc; border-radius: 12px;"><p style="font-size: 0.7rem; color: #94a3b8; margin-bottom: 2px;">Alamat</p><p style="font-weight: 700; font-size: 0.8rem;">${dudi.alamat}</p></div>
                                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px;">
                                        <div style="padding: 8px; background-color: #f8fafc; border-radius: 12px; text-align:center;"><p style="font-size: 9px; color:#94a3b8;">Jam Masuk</p><p style="font-weight: 700; font-size: 0.75rem;">${dudi.jam_berangkat}</p></div>
                                        <div style="padding: 8px; background-color: #f8fafc; border-radius: 12px; text-align:center;"><p style="font-size: 9px; color:#94a3b8;">Jam Pulang</p><p style="font-weight: 700; font-size: 0.75rem;">${dudi.jam_pulang}</p></div>
                                        <div style="padding: 8px; background-color: #f8fafc; border-radius: 12px; text-align:center;"><p style="font-size: 9px; color:#94a3b8;">Sisa Kuota</p><p style="font-weight: 700; font-size: 0.75rem;">${dudi.kuota - dudi.terdaftar}</p></div>
                                    </div>
                                </div>`;
                    }
                }
                html += `</div></div></div></div>`;
            }

            if (filePreviewData) {
                html += `
                    <div class="file-preview-overlay" onclick="closeFilePreview()">
                        <div class="file-preview-card" onclick="event.stopPropagation()">
                            <h3 style="font-size: 1.25rem; font-weight: 800; color: #003056; margin-bottom: 12px;">${filePreviewData.title}</h3>
                            ${filePreviewData.content}
                            <button onclick="closeFilePreview()" style="margin-top: 24px; background: #003056; color: white; border: none; padding: 10px 24px; border-radius: 40px; font-weight: 700; cursor: pointer;">Tutup</button>
                        </div>
                    </div>
                `;
            }

            document.getElementById('root').innerHTML = html;

            document.getElementById('searchInput')?.addEventListener('input', (e) => { searchQuery = e.target.value; render(); });
            document.getElementById('statusSelect')?.addEventListener('change', (e) => { statusFilter = e.target.value; render(); });
            document.getElementById('classSelectToolbar')?.addEventListener('change', (e) => { selectedClass = e.target.value; searchQuery = ""; statusFilter = "Semua Status"; selectedStudent = null; render(); });
            document.getElementById('printBtn')?.addEventListener('click', () => alert('Fitur cetak laporan akan segera hadir'));

            document.querySelectorAll('.detail-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const id = parseInt(btn.getAttribute('data-id'));
                    const students = MOCK_STUDENTS_BY_CLASS[selectedClass] || [];
                    const student = students.find(s => s.id === id);
                    if (student) { selectedStudent = student; activeTab = "berkas"; render(); }
                });
            });

            if (selectedStudent) {
                document.getElementById('tabBerkasBtn')?.addEventListener('click', () => { activeTab = 'berkas'; render(); });
                document.getElementById('tabPerusahaanBtn')?.addEventListener('click', () => { activeTab = 'perusahaan'; render(); });
                document.querySelectorAll('.berkas-item-click').forEach(el => {
                    el.addEventListener('click', (e) => {
                        const berkasName = el.getAttribute('data-berkas');
                        const statusVal = el.getAttribute('data-status');
                        showFilePreview(berkasName, selectedStudent.nama, statusVal);
                    });
                });
            }
        }

        window.closeModal = function(event) {
            if (event && event.target !== event.currentTarget) return;
            selectedStudent = null;
            render();
        };
        window.closeFilePreview = closeFilePreview;

        render();
    </script>
</body>
</html>