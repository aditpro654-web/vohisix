            { id: 2, nama_dudi: "Digital Creative Hub", alamat: "Gedung Cyber 2, Lt. 10, Jakarta Selatan", jam_berangkat: "09:00", jam_pulang: "18:00", bidang_industri: "Digital Marketing", jumlah_pegawai: "45", website: "www.creativehub.id", telepon: "021-8889900", email: "contact@creativehub.id", kuota: 3, penanggung_jawab: "Budi Santoso", terdaftar: 3 },
            { id: 3, nama_dudi: "Indo Cloud Solutions", alamat: "Kawasan Industri Pulo Gadung, Jakarta Timur", jam_berangkat: "08:30", jam_pulang: "17:30", bidang_industri: "Cloud Computing", jumlah_pegawai: "300", website: "www.indocloud.net", telepon: "021-1112233", email: "jobs@indocloud.net", kuota: 8, penanggung_jawab: "Agus Pratama", terdaftar: 1 }
